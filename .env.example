# General AI Trading System - Environment Variables
# Copy file này thành .env và điền thông tin của bạn

# ============================================================
# Exchange API Keys (để trống nếu dùng Paper Trading)
# ============================================================
EXCHANGE_API_KEY=
EXCHANGE_SECRET=

# ============================================================
# Optional: Chọn sàn giao dịch (mặc định: binance)
# Danh sách: binance, bybit, okx, kucoin, gate
# ============================================================
# EXCHANGE_ID=binance

# ============================================================
# Databricks Configuration (Free Edition)
# ============================================================
DATABRICKS_HOST=your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=dapi...your_token_here
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your_warehouse_id
